<mujoco model="spyder12_desert">
  <!-- Spyder-Desert-v0: the SAME spyder12 robot on procedural desert terrain.
       The robot subtree below is copied verbatim from spyder12.xml — same
       bodies, joints, actuators — so nq/nv/nbody and therefore the whole
       113-dim observation and 12-dim action are unchanged. A policy trained
       on Spyder-v0 loads here directly; only the ground under it changed.

       The world: the flat plane is replaced by a heightfield generated by
       make_terrain.py (fractal dune field + distance-gated rocky mountains +
       gravel micro-roughness, flat spawn pad at the origin — see that file's
       docstring for the full recipe). The hfield z-size and geom z-pos below
       are printed by make_terrain.py and MUST be kept in sync with the
       generated .bin, or the terrain is silently rescaled: MuJoCo normalizes
       hfield data to [0,1] and multiplies by size[2].

       Spawn height is NOT hand-tuned here: SpyderEnv measures the ground
       height under the origin from the compiled hfield and re-bases
       init_qpos z, so a regenerated terrain can't break resets. -->
  <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
  <option integrator="RK4" timestep="0.01"/>

  <visual>
    <!-- Bigger offscreen buffer for HD eval renders; 8k shadow map because a
         directional light's shadow must stretch across the whole 80 m
         heightfield (at the default 1024 the texels are ~8 cm and shadow
         acne speckles the ground black). Warm ambient headroom so the
         shadowed sides of dunes stay readable. -->
    <global offwidth="1920" offheight="1088"/>
    <quality shadowsize="8192"/>
    <map haze="0.15"/>
    <rgba haze="0.89 0.80 0.65 1"/>
  </visual>

  <default>
    <joint armature="1" damping="1" stiffness="30" limited="true"/>
    <geom condim="3" density="5.0" friction="1 0.5 0.5" margin="0.01" rgba="0.55 0.55 0.58 1"/>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="40"/>
    <default class="marker">
      <geom type="sphere" size="0.095" contype="0" conaffinity="0" density="0"/>
    </default>
  </default>

  <asset>
    <!-- Desert sky: zenith blue fading into warm horizon haze. -->
    <texture builtin="gradient" height="100" rgb1="0.40 0.60 0.85" rgb2="0.87 0.78 0.62" type="skybox" width="100"/>
    <!-- Terrain elevation: float32 binary from make_terrain.py. size =
         (x half-extent, y half-extent, elevation span, base thickness);
         the first pair matches HALF_EXTENT, the span is the generator's
         printed value. -->
    <hfield name="desert" file="terrain/desert_hfield.bin" size="40 40 5.05 1.0"/>
    <!-- Ground albedo baked from the same height data (slope-driven rock,
         height tint, sun shading, grain). texuniform=false + texrepeat 1 1
         stretches it exactly once across the hfield, so texture pixels stay
         registered to terrain cells. -->
    <texture name="texdesert" type="2d" file="terrain/desert_texture.png"/>
    <material name="MatDesert" texture="texdesert" texrepeat="1 1" texuniform="false" reflectance="0.05" shininess="0.05" specular="0.2"/>
  </asset>

  <!-- Shadow volume: a directional light's shadow map is an orthographic box
       sized by the model's statistic extent, which the 80 m heightfield
       inflates until robot-scale shadows dissolve into acne. Pinning extent
       to 10 m and letting the light TRACK the torso keeps a crisp, correctly
       biased shadow under the robot wherever it walks; terrain relief beyond
       that radius is carried by the shading baked into the albedo texture.
       (center z=1 keeps the auto camera clip planes around the action.) -->
  <statistic extent="10" center="0 0 1"/>

  <worldbody>
    <!-- Low warm sun, direction matched to the shading baked into the ground
         texture so painted and geometric shadows agree. mode=trackcom pins
         the light (and with it the shadow volume) to the robot's center of
         mass. -->
    <light cutoff="100" diffuse="1 0.96 0.88" dir="0.45 0.25 -0.86" directional="true" exponent="1" pos="0 0 10" mode="trackcom" specular=".1 .1 .1"/>
    <!-- The desert floor. pos z = generator's printed h_min offset, placing
         the spawn-pad surface at world z = 0 (where the robot expects it).
         Contact realism: real desert surface under a ~1 kg robot is FIRM —
         pavement and rock are rigid, and even loose dune sand yields only
         ~1-2 cm to feet this light. MuJoCo's default contact (solref 0.02,
         critically damped — no bounce) is already the right model, and it is
         exactly what the flat world uses, so the ground feels identical to
         every Gymnasium env. The one sand-specific term kept is sliding
         friction 0.8: dry sand shears under tangential load more easily
         than the flat world's 1.0. Two earlier "soft sand" tunes (solref
         0.04 / dampratio 2) read as quicksand on video — in MuJoCo's model
         dampratio SOFTENS stiffness (k ~ 1/dampratio^2), it does not add
         firm dissipation. True granular flow (footprints, avalanching) is
         beyond any rigid-body engine. -->
    <geom conaffinity="1" condim="3" name="floor" type="hfield" hfield="desert" material="MatDesert" pos="0 0 -0.41" friction="0.8 0.5 0.5"/>

    <body name="torso" pos="0 0 0.35">
      <camera name="track" mode="trackcom" pos="0 -3 0.3" xyaxes="1 0 0 0 0 1"/>
      <joint armature="0" damping="0" stiffness="0" limited="false" margin="0.01" name="root" pos="0 0 0" type="free"/>
      <geom name="torso_geom" pos="0 0 0" size="0.25" type="sphere" rgba="0.28 0.28 0.32 1"/>
      <geom name="stub_1" fromto="0 0 0  0.2  0.2 0" size="0.08" type="capsule"/>
      <geom name="stub_2" fromto="0 0 0 -0.2  0.2 0" size="0.08" type="capsule"/>
      <geom name="stub_3" fromto="0 0 0 -0.2 -0.2 0" size="0.08" type="capsule"/>
      <geom name="stub_4" fromto="0 0 0  0.2 -0.2 0" size="0.08" type="capsule"/>

      <!-- ═ Leg 1 · front-left (+x,+y) ═ -->
      <body name="coxa_1" pos="0.2 0.2 0">
        <joint name="hip_1" type="hinge" axis="0 0 1" pos="0 0 0" range="-40 40"/>
        <geom class="marker" rgba="0.85 0.20 0.20 1"/>
        <geom name="coxa_1_geom" fromto="0 0 0 0.12 0.12 0" size="0.08" type="capsule"/>
        <body name="femur_1" pos="0.12 0.12 0">
          <joint name="lift_1" type="hinge" axis="-1 1 0" pos="0 0 0" range="-60 60"/>
          <geom class="marker" rgba="0.15 0.65 0.25 1"/>
          <geom name="femur_1_geom" fromto="0 0 0 0.22 0.22 0.25" size="0.08" type="capsule"/>
          <body name="tibia_1" pos="0.22 0.22 0.25">
            <joint name="knee_1" type="hinge" axis="-1 1 0" pos="0 0 0" range="-50 50"/>
            <geom class="marker" rgba="0.20 0.40 0.85 1"/>
            <geom name="tibia_1_geom" fromto="0 0 0 0.22 0.22 -0.52" size="0.08" type="capsule"/>
          </body>
        </body>
      </body>

      <!-- ═ Leg 2 · front-right (-x,+y) ═ -->
      <body name="coxa_2" pos="-0.2 0.2 0">
        <joint name="hip_2" type="hinge" axis="0 0 1" pos="0 0 0" range="-40 40"/>
        <geom class="marker" rgba="0.85 0.20 0.20 1"/>
        <geom name="coxa_2_geom" fromto="0 0 0 -0.12 0.12 0" size="0.08" type="capsule"/>
        <body name="femur_2" pos="-0.12 0.12 0">
          <joint name="lift_2" type="hinge" axis="1 1 0" pos="0 0 0" range="-60 60"/>
          <geom class="marker" rgba="0.15 0.65 0.25 1"/>
          <geom name="femur_2_geom" fromto="0 0 0 -0.22 0.22 0.25" size="0.08" type="capsule"/>
          <body name="tibia_2" pos="-0.22 0.22 0.25">
            <joint name="knee_2" type="hinge" axis="1 1 0" pos="0 0 0" range="-50 50"/>
            <geom class="marker" rgba="0.20 0.40 0.85 1"/>
            <geom name="tibia_2_geom" fromto="0 0 0 -0.22 0.22 -0.52" size="0.08" type="capsule"/>
          </body>
        </body>
      </body>

      <!-- ═ Leg 3 · back-left (-x,-y) ═ -->
      <body name="coxa_3" pos="-0.2 -0.2 0">
        <joint name="hip_3" type="hinge" axis="0 0 1" pos="0 0 0" range="-40 40"/>
        <geom class="marker" rgba="0.85 0.20 0.20 1"/>
        <geom name="coxa_3_geom" fromto="0 0 0 -0.12 -0.12 0" size="0.08" type="capsule"/>
        <body name="femur_3" pos="-0.12 -0.12 0">
          <joint name="lift_3" type="hinge" axis="-1 1 0" pos="0 0 0" range="-60 60"/>
          <geom class="marker" rgba="0.15 0.65 0.25 1"/>
          <geom name="femur_3_geom" fromto="0 0 0 -0.22 -0.22 0.25" size="0.08" type="capsule"/>
          <body name="tibia_3" pos="-0.22 -0.22 0.25">
            <joint name="knee_3" type="hinge" axis="-1 1 0" pos="0 0 0" range="-50 50"/>
            <geom class="marker" rgba="0.20 0.40 0.85 1"/>
            <geom name="tibia_3_geom" fromto="0 0 0 -0.22 -0.22 -0.52" size="0.08" type="capsule"/>
          </body>
        </body>
      </body>

      <!-- ═ Leg 4 · back-right (+x,-y) ═ -->
      <body name="coxa_4" pos="0.2 -0.2 0">
        <joint name="hip_4" type="hinge" axis="0 0 1" pos="0 0 0" range="-40 40"/>
        <geom class="marker" rgba="0.85 0.20 0.20 1"/>
        <geom name="coxa_4_geom" fromto="0 0 0 0.12 -0.12 0" size="0.08" type="capsule"/>
        <body name="femur_4" pos="0.12 -0.12 0">
          <joint name="lift_4" type="hinge" axis="1 1 0" pos="0 0 0" range="-60 60"/>
          <geom class="marker" rgba="0.15 0.65 0.25 1"/>
          <geom name="femur_4_geom" fromto="0 0 0 0.22 -0.22 0.25" size="0.08" type="capsule"/>
          <body name="tibia_4" pos="0.22 -0.22 0.25">
            <joint name="knee_4" type="hinge" axis="1 1 0" pos="0 0 0" range="-50 50"/>
            <geom class="marker" rgba="0.20 0.40 0.85 1"/>
            <geom name="tibia_4_geom" fromto="0 0 0 0.22 -0.22 -0.52" size="0.08" type="capsule"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="hip_1"  joint="hip_1"/>
    <motor name="lift_1" joint="lift_1"/>
    <motor name="knee_1" joint="knee_1"/>
    <motor name="hip_2"  joint="hip_2"/>
    <motor name="lift_2" joint="lift_2"/>
    <motor name="knee_2" joint="knee_2"/>
    <motor name="hip_3"  joint="hip_3"/>
    <motor name="lift_3" joint="lift_3"/>
    <motor name="knee_3" joint="knee_3"/>
    <motor name="hip_4"  joint="hip_4"/>
    <motor name="lift_4" joint="lift_4"/>
    <motor name="knee_4" joint="knee_4"/>
  </actuator>
</mujoco>
